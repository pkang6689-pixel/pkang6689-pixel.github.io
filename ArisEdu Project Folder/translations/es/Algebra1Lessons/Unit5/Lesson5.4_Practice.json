{
  "What is a geometric sequence?": "",
  "A sequence with a constant ratio between consecutive terms": "",
  "What is the common ratio?": "",
  "The constant value multiplied to get from one term to the next": "",
  "What is the explicit formula?": "",
  "a(n) = a(1) · r^(n−1)": "",
  "Find the common ratio of 4, 12, 36, 108.": "",
  "r = 3": "",
  "Find the 5th term of 2, 6, 18, 54, ...": "",
  "a(5) = 2 · 3⁴ = 162": "",
  "If |r| > 1, the sequence:": "",
  "Grows (values increase in magnitude)": "",
  "If 0 < |r| < 1, the sequence:": "",
  "Decays (values decrease toward zero)": "",
  "Is 5, 15, 45, 135 geometric?": "",
  "Yes — common ratio r = 3": "",
  "If r = −2 in a geometric sequence:": "",
  "The terms alternate in sign": "",
  "Find the 4th term of 5, 10, 20, ...": "",
  "a(4) = 5 · 2³ = 40": ""
}