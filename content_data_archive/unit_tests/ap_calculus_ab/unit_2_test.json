      "q": "Which of the following functions is continuous at x = 0?",
      "options": [
        "f(x) = 1/x",
        "f(x) = |x|",
        "f(x) = tan(x)/x for x≠0",
        "f(x) = x²sin(1/x) for x≠0"
      ],
      "answer": "f(x) = |x|",
      "difficulty": "hard",
      "id": "u2_q1",
      "source": "College Board Past AP Exams",
      "type": "mc"
    },
