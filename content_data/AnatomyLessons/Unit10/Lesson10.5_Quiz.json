    {
      "question_number": 1,
      "question_text": "A marathon runner collapses. Which systems are involved?",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "Only muscular",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Only cardiovascular",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Cardiovascular (dehydration ↓ CO), thermoregulatory (hyperthermia), renal (↓ GFR), musculoskeletal, nervous (confusion), and endocrine",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "Only respiratory",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "Multi-system stress."
    },
    {
