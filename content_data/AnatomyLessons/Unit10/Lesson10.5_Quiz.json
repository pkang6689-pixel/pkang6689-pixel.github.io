          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Only respiratory",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Immune (IgE/mast cells → histamine), cardiovascular (vasodilation → shock), respiratory (bronchospasm → airway obstruction), skin (urticaria)",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "Only cardiovascular",
          "is_correct": false,
          "data_i18n": null
        }
      ],
