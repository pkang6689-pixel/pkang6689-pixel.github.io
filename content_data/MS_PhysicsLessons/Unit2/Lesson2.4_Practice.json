{
  "unit": 2,
  "lesson_number": "2.4",
  "title": "Equations of Motion (constant acceleration)",
  "course": "MS Physics",
  "flashcards": [
    {
      "term": "v = v₀ + at",
      "definition": "Final velocity = initial velocity + (acceleration × time)."
    },
    {
      "term": "x = v₀t + ½at²",
      "definition": "Displacement = initial velocity × time + half acceleration × time²."
    },
    {
      "term": "v² = v₀² + 2ax",
      "definition": "Relates velocity, acceleration, and displacement without time."
    },
    {
      "term": "x = ½(v₀ + v)t",
      "definition": "Displacement = average velocity × time."
    },
    {
      "term": "Constant Acceleration",
      "definition": "These kinematic equations only apply when acceleration is constant."
    }
  ]
}