    {
      "term": "Capacitance",
      "definition": "C = Q/V; ability to store charge. Units: farads (F)."
    },
    {
      "term": "Parallel Plate Capacitor",
      "definition": "C = ε₀A/d; capacitance depends on area, distance, and dielectric."
    },
    {
      "term": "Dielectric",
      "definition": "Insulating material between plates that increases capacitance."
    },
    {
      "term": "Energy Stored",
      "definition": "U = ½CV² = ½QV = Q²/(2C)."
    },
    {
      "term": "Capacitors in Series/Parallel",
      "definition": "Series: 1/C_total = Σ(1/Cᵢ). Parallel: C_total = ΣCᵢ."
    }
  ]
