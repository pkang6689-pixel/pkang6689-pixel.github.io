    {
      "question_number": 3,
      "question_text": "Variance is the:",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "Square root of the standard deviation",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Mean divided by n",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Average of squared deviations from the mean",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "Range divided by 2",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "Variance = Σ(x − x̄)² / (n − 1) for a sample."
    },
    {
      "question_number": 4,
      "question_text": "Why do we use n−1 in sample variance?",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "To make the calculation simpler",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "To produce an unbiased estimate of the population variance (Bessel's correction)",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "It doesn't matter",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Because n is always wrong",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "Dividing by n−1 corrects for the bias that arises from estimating the mean from the sample itself."
    },
