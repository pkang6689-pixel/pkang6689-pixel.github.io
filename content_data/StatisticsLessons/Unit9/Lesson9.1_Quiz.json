      "question_number": 1,
      "question_text": "The Law of Large Numbers states that as trial count increases:",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "Each trial becomes more predictable",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "The sample mean approaches the population mean",
          "is_correct": true,
          "data_i18n": null
