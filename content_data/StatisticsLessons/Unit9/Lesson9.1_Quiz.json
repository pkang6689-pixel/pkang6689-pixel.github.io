        {
          "text": "Variance increases",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Outcomes become less random",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "LLN is about the convergence of the average, not individual outcomes."
    },
    {
