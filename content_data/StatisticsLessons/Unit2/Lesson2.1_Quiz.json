      "question_number": 1,
      "question_text": "A frequency table shows:",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "Only the mean",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "How often each value or group of values occurs",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "Just the highest value",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Only percentages",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "A frequency table lists values or classes with the count of observations for each."
    },
    {
      "question_number": 2,
      "question_text": "Relative frequency is calculated as:",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "f × n",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "f / n (frequency divided by total)",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "n / f",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "f + n",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "Relative frequency equals the frequency of a class divided by the total number of observations."
    },
    {
      "question_number": 3,
      "question_text": "Cumulative frequency:",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "Resets for each class",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Is a running total of frequencies up to each class",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "Equals the mean",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Only applies to nominal data",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "Cumulative frequency adds each class's frequency to the sum of all previous classes."
    },
