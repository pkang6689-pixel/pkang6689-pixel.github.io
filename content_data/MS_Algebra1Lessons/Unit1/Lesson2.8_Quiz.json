      "data_i18n": null,
      "options": [
        {
          "text": "6 T-shirts and 2 hats",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "4 T-shirts and 4 hats",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "5 T-shirts and 3 hats",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "3 T-shirts and 5 hats",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "From t + h = 8: h = 8 - t. Substitute: 15t + 10(8 - t) = 100, 15t + 80 - 10t = 100, 5t = 20, t = 4. h = 4."
