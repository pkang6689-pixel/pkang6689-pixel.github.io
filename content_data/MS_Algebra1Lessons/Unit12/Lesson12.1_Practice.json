    },
    {
      "question": "How do you calculate probability?",
      "answer": "P(E) = favorable outcomes ÷ total outcomes",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Probability is always between:",
      "answer": "0 and 1 (inclusive)",
