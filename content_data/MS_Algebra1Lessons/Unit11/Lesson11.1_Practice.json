      "question": "What is an arithmetic sequence?",
      "answer": "A sequence with a constant difference (d) between consecutive terms",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "What is a geometric sequence?",
      "answer": "A sequence with a constant ratio (r) between consecutive terms",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Arithmetic formula:",
      "answer": "a(n) = a(1) + (n − 1)d",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Geometric formula:",
      "answer": "a(n) = a(1) · r^(n − 1)",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Is 3, 6, 12, 24 arithmetic or geometric?",
      "answer": "Geometric (r = 2)",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Is 5, 8, 11, 14 arithmetic or geometric?",
      "answer": "Arithmetic (d = 3)",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Find the 8th term of 2, 5, 8, 11, ...",
