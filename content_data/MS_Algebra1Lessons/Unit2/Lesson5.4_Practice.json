  "unit": 5,
  "lesson_number": "5.4",
  "title": "Geometric Sequences",
  "course": "MS Algebra 1",
  "flashcards": [
    {
      "question": "What is a geometric sequence?",
      "answer": "A sequence with a constant ratio between consecutive terms",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "What is the common ratio?",
      "answer": "The constant value multiplied to get from one term to the next",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "What is the explicit formula?",
      "answer": "a(n) = a(1) · r^(n−1)",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Find the common ratio of 4, 12, 36, 108.",
      "answer": "r = 3",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Find the 5th term of 2, 6, 18, 54, ...",
      "answer": "a(5) = 2 · 3⁴ = 162",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "If |r| > 1, the sequence:",
      "answer": "Grows (values increase in magnitude)",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "If 0 < |r| < 1, the sequence:",
      "answer": "Decays (values decrease toward zero)",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Is 5, 15, 45, 135 geometric?",
      "answer": "Yes — common ratio r = 3",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "If r = −2 in a geometric sequence:",
      "answer": "The terms alternate in sign",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Find the 4th term of 5, 10, 20, ...",
      "answer": "a(4) = 5 · 2³ = 40",
      "data_i18n_q": null,
      "data_i18n_a": null
    }
  ]
}