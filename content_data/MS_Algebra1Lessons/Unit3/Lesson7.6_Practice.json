    {
      "question": "What is the discriminant?",
      "answer": "D = b² − 4ac — the expression under the square root in the quadratic formula",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "If D > 0:",
      "answer": "Two distinct real solutions",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "If D = 0:",
      "answer": "One repeated real solution (double root)",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "If D < 0:",
      "answer": "No real solutions (two complex solutions)",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Find the discriminant of x² + 6x + 9 = 0.",
      "answer": "D = 36 − 36 = 0 → one repeated solution",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Find the discriminant of x² + 2x + 5 = 0.",
      "answer": "D = 4 − 20 = −16 → no real solutions",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "How many times does the parabola cross the x-axis if D > 0?",
