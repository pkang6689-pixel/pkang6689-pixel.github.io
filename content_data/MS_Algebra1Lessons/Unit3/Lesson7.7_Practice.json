    {
      "question": "A linear-quadratic system can have how many solutions?",
      "answer": "0, 1, or 2 solutions",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "How do you solve a linear-quadratic system?",
      "answer": "Substitution: set the linear equation equal to the quadratic and solve",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "What are solutions graphically?",
      "answer": "The intersection points of the line and parabola",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "If a line is tangent to a parabola:",
      "answer": "The system has exactly 1 solution",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "If a line doesn't intersect a parabola:",
      "answer": "The system has no solution",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Solve: y = x², y = x + 2",
      "answer": "x² = x + 2 → x² − x − 2 = 0 → (x−2)(x+1) = 0 → x = 2 or x = −1",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Solve: y = x² − 1, y = 3",
      "answer": "x² − 1 = 3 → x² = 4 → x = ±2",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "A system of two quadratics can have:",
      "answer": "0, 1, or 2 solutions",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Can a quadratic-quadratic system have more than 2 solutions?",
      "answer": "No — two parabolas can intersect at most twice",
      "data_i18n_q": null,
      "data_i18n_a": null
    },
    {
      "question": "Solve: y = x² + 1, y = 2x + 1",
      "answer": "x² + 1 = 2x + 1 → x² − 2x = 0 → x(x − 2) = 0 → x = 0 or x = 2",
      "data_i18n_q": null,
      "data_i18n_a": null
    }
  ]
