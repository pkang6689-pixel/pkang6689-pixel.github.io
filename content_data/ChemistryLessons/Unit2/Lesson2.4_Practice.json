      "term": "SI System",
      "definition": "The International System of Units — the standard system of measurement in science."
    },
    {
      "term": "Kilo-",
      "definition": "SI prefix meaning 1,000 (10³). 1 kg = 1,000 g."
    },
    {
      "term": "Centi-",
      "definition": "SI prefix meaning 1/100 (10⁻²). 1 cm = 0.01 m."
    },
    {
      "term": "Milli-",
      "definition": "SI prefix meaning 1/1,000 (10⁻³). 1 mL = 0.001 L."
    },
    {
      "term": "Base Units",
      "definition": "Fundamental SI units: meter (m), kilogram (kg), second (s), kelvin (K), mole (mol)."
    }
  ]
