    {
      "term": "pH Scale",
      "definition": "Measures acidity: 0–6.9 acidic, 7 neutral, 7.1–14 basic."
    },
    {
      "term": "pH",
      "definition": "−log[H⁺]; lower pH = more acidic."
    },
    {
      "term": "pOH",
      "definition": "−log[OH⁻]; lower pOH = more basic."
    },
    {
      "term": "pH + pOH = 14",
      "definition": "At 25°C, the sum of pH and pOH always equals 14."
    },
    {
      "term": "Neutral Solution",
      "definition": "pH = 7; [H⁺] = [OH⁻] = 10⁻⁷ M at 25°C."
    }
  ]
}