      "term": "Speed of Sound in Air",
      "definition": "≈ 343 m/s at 20°C; increases with temperature."
    },
    {
      "term": "Speed Depends on Medium",
      "definition": "Fastest in solids, slowest in gases (denser, stiffer media → faster)."
    },
    {
      "term": "Temperature Dependence",
      "definition": "v ≈ 331 + 0.6T (m/s) where T is in °C."
    },
    {
      "term": "Mach Number",
      "definition": "Ratio of object's speed to speed of sound: Mach 1 = speed of sound."
    },
    {
      "term": "Sonic Boom",
      "definition": "Shock wave produced when an object exceeds the speed of sound."
    }
  ]
