  "unit": 7,
  "lesson_number": "7.2",
  "title": "Period, Frequency, Amplitude",
  "course": "Physics",
  "flashcards": [
    {
      "term": "Period (T)",
      "definition": "Time for one complete oscillation; measured in seconds."
    },
    {
      "term": "Frequency (f)",
      "definition": "Number of oscillations per second: f = 1/T; measured in hertz (Hz)."
    },
    {
      "term": "Amplitude (A)",
      "definition": "Maximum displacement from equilibrium."
    },
    {
      "term": "Angular Frequency",
      "definition": "ω = 2πf = 2π/T; measured in rad/s."
    },
    {
      "term": "Period of a Pendulum",
      "definition": "T = 2π√(L/g); depends on length and gravity, not mass."
    }
  ]
}