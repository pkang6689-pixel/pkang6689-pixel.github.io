  "title": "Conservation of Momentum",
  "course": "Physics",
  "flashcards": [
    {
      "term": "Conservation of Momentum",
      "definition": "In an isolated system, total momentum before = total momentum after."
    },
    {
      "term": "Isolated System",
      "definition": "No external forces act on the system."
    },
    {
      "term": "Before and After",
      "definition": "Σp_before = Σp_after."
    },
    {
      "term": "Vector Nature",
      "definition": "Momentum is conserved in each direction independently."
    },
    {
      "term": "Application",
      "definition": "Collisions, explosions, recoil."
    }
  ]
}