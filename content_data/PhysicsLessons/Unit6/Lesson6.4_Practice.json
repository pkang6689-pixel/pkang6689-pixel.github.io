      "term": "Low Earth Orbit (LEO)",
      "definition": "Altitude ~200–2,000 km; period ~90 minutes."
    },
    {
      "term": "Geostationary Orbit",
      "definition": "Fixed position above the equator; used for communications."
    },
    {
      "term": "Polar Orbit",
      "definition": "Passes over both poles; used for Earth observation."
    },
    {
