    {
      "term": "sin(A/2)",
      "definition": "±√((1 − cos A)/2); sign determined by the quadrant of A/2."
    },
    {
      "term": "cos(A/2)",
      "definition": "±√((1 + cos A)/2); sign determined by the quadrant of A/2."
    },
    {
      "term": "tan(A/2) — form 1",
      "definition": "sin A / (1 + cos A)."
    },
    {
      "term": "tan(A/2) — form 2",
      "definition": "(1 − cos A) / sin A."
    },
    {
      "term": "Choosing the Sign",
      "definition": "Determine which quadrant A/2 is in to decide + or −."
    }
  ]
