    {
      "question_number": 3,
      "question_text": "Two forces of 100 N and 150 N act at 60° apart. Resultant magnitude:",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "250 N",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "50 N",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "√(100²+150²+2·100·150·cos60°) = √(10000+22500+15000) = √47500 ≈ 217.9 N",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "100 N",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "Law of Cosines for vector addition."
