    {
      "question_number": 8,
      "question_text": "A surveyor at point A sights point C at 40° from the baseline AB. At B, C is at 60° from BA. AB = 200 m. Find AC:",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "200 m",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Using Law of Sines: angle C = 80°, AC = 200 sin 60° / sin 80° ≈ 175.9 m",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "200 sin 40°",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "300 m",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "C = 180°−40°−60° = 80°. AC/sinB = AB/sinC."
