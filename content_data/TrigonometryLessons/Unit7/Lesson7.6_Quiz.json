    {
      "question_number": 6,
      "question_text": "An arch spans 20 m with a rise of 5 m. The radius of a circular arch:",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "5 m",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "20 m",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "R = (s²/(8h)) + h/2 = (400/40) + 2.5 = 12.5 m",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "10 m",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "Using the sagitta formula: R = s²/(8h) + h/2."
    },
