      "data_i18n": null,
      "options": [
        {
          "text": "a² = b² + c² − 2bc cos A",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "a/sin A = b/sin B = c/sin C",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "sin A + sin B = sin C",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "a sin A = b sin B",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "Equal ratios of side to sine of opposite angle."
    },
    {
