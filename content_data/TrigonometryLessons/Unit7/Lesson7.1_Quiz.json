        {
          "text": "b = 10 cos 60°",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "b = 10 tan 60°",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "b/sin B = a/sin A → b = a sin B / sin A."
