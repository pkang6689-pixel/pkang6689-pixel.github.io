  "title": "Area of Triangles",
  "course": "Trigonometry",
  "flashcards": [
    {
      "term": "Sine Area Formula",
      "definition": "Area = ½ ab sin C; efficient with SAS data."
    },
    {
      "term": "Heron's Formula",
      "definition": "Area = √(s(s−a)(s−b)(s−c)) where s = (a+b+c)/2."
    },
    {
      "term": "Semi-perimeter (s)",
      "definition": "s = (a + b + c) / 2; used in Heron's formula."
    },
    {
      "term": "When to Use Sine Formula",
      "definition": "When two sides and their included angle are known (SAS)."
    },
    {
      "term": "When to Use Heron's",
      "definition": "When all three sides are known (SSS)."
    }
  ]
}