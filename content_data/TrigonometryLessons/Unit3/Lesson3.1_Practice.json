  "title": "Definition & Domains of Inverse Trig Functions",
  "course": "Trigonometry",
  "flashcards": [
    {
      "term": "arcsin (sin⁻¹)",
      "definition": "Inverse sine; domain [−1, 1], range [−π/2, π/2]."
    },
    {
      "term": "arccos (cos⁻¹)",
      "definition": "Inverse cosine; domain [−1, 1], range [0, π]."
    },
    {
      "term": "arctan (tan⁻¹)",
      "definition": "Inverse tangent; domain (−∞, ∞), range (−π/2, π/2)."
    },
    {
      "term": "Principal Value",
      "definition": "The unique output of an inverse trig function within its restricted range."
    },
    {
      "term": "Domain Restriction",
      "definition": "Limiting the domain of a trig function so it becomes one-to-one and thus invertible."
    }
  ]
}