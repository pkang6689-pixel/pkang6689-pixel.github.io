        {
          "text": "x² + (y−3)² = 9",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "x² + y² = 9",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "(x+3)² + y² = 9",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "x² + y² − 6y = 0 → x² + (y²−6y+9) = 9 → x² + (y−3)² = 9."
