{
  "unit": 8,
  "lesson_number": "8.3",
  "title": "Converting Polar & Rectangular Coordinates",
  "course": "Trigonometry",
  "flashcards": [
    {
      "term": "Polar → Rectangular",
      "definition": "x = r cos θ, y = r sin θ."
    },
    {
      "term": "Rectangular → Polar",
      "definition": "r = √(x²+y²), θ = arctan(y/x) (with quadrant adjustment)."
    },
    {
      "term": "r² = x² + y²",
      "definition": "Links the radial distance to Cartesian coordinates."
    },
    {
      "term": "Equation Conversion",
      "definition": "Replace r², r cos θ, r sin θ with x²+y², x, y (or vice versa)."
    },
    {
      "term": "Quadrant Adjustment",
      "definition": "arctan gives values in (−π/2, π/2); add π for Q II/III points."
    }
  ]
}