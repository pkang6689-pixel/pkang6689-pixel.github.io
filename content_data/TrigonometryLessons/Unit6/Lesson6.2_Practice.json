{
  "unit": 6,
  "lesson_number": "6.2",
  "title": "Solving Quadratic Trig Equations",
  "course": "Trigonometry",
  "flashcards": [
    {
      "term": "Substitution Method",
      "definition": "Let u = sinθ (or cosθ) to convert to au²+bu+c = 0."
    },
    {
      "term": "Factoring",
      "definition": "Factor the quadratic, then set each factor to zero."
    },
    {
      "term": "Quadratic Formula",
      "definition": "u = (−b ± √(b²−4ac)) / 2a when factoring is difficult."
    },
    {
      "term": "Reject Extraneous Solutions",
      "definition": "Discard u values outside [−1,1] for sin/cos."
    },
    {
      "term": "Back-Substitute",
      "definition": "Replace u with the trig function and solve for θ."
    }
  ]
}