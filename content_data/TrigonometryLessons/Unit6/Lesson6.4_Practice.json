  "title": "General Solutions & Periodicity",
  "course": "Trigonometry",
  "flashcards": [
    {
      "term": "General Solution (sin)",
      "definition": "θ = arcsin(k) + 2nπ or θ = π − arcsin(k) + 2nπ, n ∈ ℤ."
    },
    {
      "term": "General Solution (cos)",
      "definition": "θ = ±arccos(k) + 2nπ, n ∈ ℤ."
    },
    {
      "term": "General Solution (tan)",
      "definition": "θ = arctan(k) + nπ, n ∈ ℤ (period π)."
    },
    {
      "term": "n ∈ ℤ",
      "definition": "n is any integer: …, −2, −1, 0, 1, 2, …"
    },
    {
      "term": "Why Use General Solutions",
      "definition": "When the domain is all reals, there are infinitely many solutions — general form captures them all."
    }
  ]
}