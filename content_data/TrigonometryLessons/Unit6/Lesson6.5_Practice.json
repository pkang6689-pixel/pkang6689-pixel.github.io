  "title": "Modeling with Trig Equations",
  "course": "Trigonometry",
  "flashcards": [
    {
      "term": "Sinusoidal Model",
      "definition": "y = A sin(Bt − C) + D or y = A cos(Bt − C) + D for periodic phenomena."
    },
    {
      "term": "A = Amplitude",
      "definition": "(max − min)/2; the intensity of variation."
    },
    {
      "term": "B = Frequency Factor",
      "definition": "B = 2π/period; controls how fast the cycle repeats."
    },
    {
      "term": "D = Vertical Shift",
      "definition": "(max + min)/2; the average value."
    },
    {
      "term": "C/B = Phase Shift",
      "definition": "Horizontal shift aligning the model with data."
    }
  ]
}