  "title": "Right Triangle Ratios (SOH-CAH-TOA)",
  "course": "Trigonometry",
  "flashcards": [
    {
      "term": "Sine (sin)",
      "definition": "sin θ = opposite / hypotenuse."
    },
    {
      "term": "Cosine (cos)",
      "definition": "cos θ = adjacent / hypotenuse."
    },
    {
      "term": "Tangent (tan)",
      "definition": "tan θ = opposite / adjacent."
    },
    {
      "term": "SOH-CAH-TOA",
      "definition": "Mnemonic: Sine = Opposite/Hypotenuse, Cosine = Adjacent/Hypotenuse, Tangent = Opposite/Adjacent."
    },
    {
      "term": "Hypotenuse",
      "definition": "The longest side of a right triangle, opposite the 90° angle."
    }
  ]
}