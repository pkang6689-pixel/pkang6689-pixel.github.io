      "definition": "An isosceles right triangle with side ratio 1 : 1 : √2."
    },
    {
      "term": "30-60-90 Triangle",
      "definition": "A right triangle with side ratio 1 : √3 : 2 (short leg : long leg : hypotenuse)."
    },
    {
      "term": "sin 30°",
      "definition": "sin 30° = 1/2."
    },
    {
      "term": "cos 45°",
      "definition": "cos 45° = √2/2 ≈ 0.707."
    },
    {
      "term": "tan 60°",
      "definition": "tan 60° = √3 ≈ 1.732."
    }
