  "title": "Unit Circle Basics",
  "course": "Trigonometry",
  "flashcards": [
    {
      "term": "Unit Circle",
      "definition": "A circle with radius 1 centered at the origin; points are (cos θ, sin θ)."
    },
    {
      "term": "Coordinates at 0°",
      "definition": "(1, 0) — cos 0° = 1, sin 0° = 0."
    },
    {
      "term": "Coordinates at 90°",
      "definition": "(0, 1) — cos 90° = 0, sin 90° = 1."
    },
    {
      "term": "Coordinates at 180°",
      "definition": "(−1, 0) — cos 180° = −1, sin 180° = 0."
    },
    {
      "term": "Coordinates at 270°",
      "definition": "(0, −1) — cos 270° = 0, sin 270° = −1."
    }
  ]
}