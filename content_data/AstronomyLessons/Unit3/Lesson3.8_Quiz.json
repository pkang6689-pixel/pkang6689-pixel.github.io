        {
          "text": "27 years (T² = 729, T = 27)",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "3 years",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "T² = 9³ = 729; T = √729 = 27."
