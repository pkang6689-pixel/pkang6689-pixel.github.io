  "title": "Polar Coordinates and Complex Numbers",
  "course": "MS Geometry",
  "flashcards": [
    {
      "term": "Polar Coordinates",
      "definition": "(r, θ) where r is distance from origin and θ is angle from positive x-axis."
    },
    {
      "term": "Converting Polar to Rectangular",
      "definition": "x = r cos θ, y = r sin θ."
    },
    {
      "term": "Converting Rectangular to Polar",
      "definition": "r = √(x² + y²), θ = arctan(y/x)."
    },
    {
      "term": "Complex Number",
      "definition": "a + bi; plotted on the complex plane (real axis, imaginary axis)."
    },
    {
      "term": "Polar Form of Complex Numbers",
      "definition": "z = r(cos θ + i sin θ) = r cis θ."
    }
  ]
}