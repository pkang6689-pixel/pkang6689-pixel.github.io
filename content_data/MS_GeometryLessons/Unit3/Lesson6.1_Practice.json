    {
      "term": "Interior Angle Sum",
      "definition": "(n − 2) × 180°; the sum of interior angles of an n-sided polygon."
    },
    {
      "term": "Exterior Angle Sum",
      "definition": "Always 360° for any convex polygon."
    },
    {
      "term": "Regular Polygon Interior Angle",
      "definition": "Each angle = (n − 2) × 180° / n."
    },
    {
      "term": "Diagonal",
      "definition": "A segment connecting two non-adjacent vertices."
    },
    {
      "term": "Number of Diagonals",
      "definition": "n(n − 3)/2 diagonals in an n-sided polygon."
    }
  ]
