  "title": "<span class=\"translatable\" data-en=\"Angle\">Angle</span> Measure",
  "course": "MS Geometry",
  "flashcards": [
    {
      "term": "Angle",
      "definition": "A figure formed by two rays sharing a common endpoint (vertex)."
    },
    {
      "term": "Vertex",
      "definition": "The common endpoint of two rays forming an angle."
    },
    {
      "term": "Acute Angle",
      "definition": "An angle measuring between 0° and 90°."
    },
    {
      "term": "Right Angle",
      "definition": "An angle measuring exactly 90°."
    },
    {
      "term": "Obtuse Angle",
      "definition": "An angle measuring between 90° and 180°."
    }
  ]
}