    {
      "term": "Angle Addition Postulate",
      "definition": "If D is in the interior of ∠ABC, then m∠ABD + m∠DBC = m∠ABC."
    },
    {
      "term": "Congruent Supplements Theorem",
      "definition": "If two angles are supplementary to the same angle, they're congruent."
    },
    {
      "term": "Congruent Complements Theorem",
      "definition": "If two angles are complementary to the same angle, they're congruent."
    },
    {
      "term": "Vertical Angles Theorem",
      "definition": "Vertical angles are congruent."
    },
    {
      "term": "Right Angle Congruence",
      "definition": "All right angles are congruent."
    }
  ]
