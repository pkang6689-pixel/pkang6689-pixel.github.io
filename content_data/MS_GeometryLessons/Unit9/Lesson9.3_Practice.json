  "flashcards": [
    {
      "term": "Rotation",
      "definition": "A transformation that turns a figure around a center point."
    },
    {
      "term": "Center of Rotation",
      "definition": "The fixed point around which the figure rotates."
    },
    {
      "term": "90° Rotation (CCW)",
      "definition": "(x, y) → (−y, x)."
    },
    {
      "term": "180° Rotation",
      "definition": "(x, y) → (−x, −y)."
    },
    {
      "term": "270° Rotation (CCW)",
      "definition": "(x, y) → (y, −x)."
    }
  ]
}