    {
      "term": "Composition of Transformations",
      "definition": "Performing two or more transformations in sequence."
    },
    {
      "term": "Glide Reflection",
      "definition": "A translation followed by a reflection along the direction of translation."
    },
    {
      "term": "Two Reflections over Parallel Lines",
      "definition": "Equivalent to a single translation."
    },
    {
      "term": "Two Reflections over Intersecting Lines",
      "definition": "Equivalent to a single rotation."
    },
    {
      "term": "Order Matters",
      "definition": "The order of transformations can affect the final image."
    }
  ]
