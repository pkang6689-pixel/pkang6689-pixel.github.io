  "title": "Special Segments in a <span class=\"translatable\" data-en=\"Circle\">Circle</span>",
  "course": "MS Geometry",
  "flashcards": [
    {
      "term": "Chord-Chord Product",
      "definition": "If two chords intersect inside: (seg₁)(seg₂) = (seg₃)(seg₄)."
    },
    {
      "term": "Secant-Secant Product",
      "definition": "From outside: (whole₁)(external₁) = (whole₂)(external₂)."
    },
    {
      "term": "Secant-Tangent Product",
      "definition": "(whole secant)(external) = (tangent)²."
    },
    {
      "term": "Power of a Point",
      "definition": "The common value of these products for a given point."
    },
    {
      "term": "Application",
      "definition": "Finding unknown segment lengths using these relationships."
    }
  ]
}