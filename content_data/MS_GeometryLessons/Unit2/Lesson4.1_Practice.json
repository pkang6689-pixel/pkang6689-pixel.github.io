  "unit": 4,
  "lesson_number": "4.1",
  "title": "Classifying Triangles",
  "course": "MS Geometry",
  "flashcards": [
    {
      "term": "Scalene Triangle",
      "definition": "No sides congruent."
    },
    {
      "term": "Isosceles Triangle",
      "definition": "At least two sides congruent."
    },
    {
      "term": "Equilateral Triangle",
      "definition": "All three sides congruent (also equiangular: all angles 60°)."
    },
    {
      "term": "Acute Triangle",
      "definition": "All angles are less than 90°."
    },
    {
      "term": "Obtuse Triangle",
      "definition": "One angle is greater than 90°."
    }
  ]
}