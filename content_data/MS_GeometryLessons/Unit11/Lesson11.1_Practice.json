  "title": "Areas of Parallelograms and Triangles",
  "course": "MS Geometry",
  "flashcards": [
    {
      "term": "Area of Parallelogram",
      "definition": "A = bh; base × height."
    },
    {
      "term": "Area of Triangle",
      "definition": "A = ½bh; half base × height."
    },
    {
      "term": "Base and Height",
      "definition": "Height is always perpendicular to the base."
    },
    {
      "term": "Altitude",
      "definition": "The perpendicular distance from the base to the opposite vertex (= height)."
    },
    {
      "term": "Units of Area",
      "definition": "Area is measured in square units (cm², m², in², ft²)."
    }
  ]
}