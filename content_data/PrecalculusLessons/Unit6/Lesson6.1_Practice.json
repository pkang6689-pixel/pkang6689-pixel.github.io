  "title": "Angles in Degrees & Radians",
  "course": "Precalculus",
  "flashcards": [
    {
      "term": "Radian",
      "definition": "The angle subtended by an arc equal in length to the radius; 2π rad = 360°."
    },
    {
      "term": "Degree",
      "definition": "1/360 of a full rotation."
    },
    {
      "term": "Degrees to Radians",
      "definition": "Multiply by π/180."
    },
    {
      "term": "Radians to Degrees",
      "definition": "Multiply by 180/π."
    },
    {
      "term": "Standard Position",
      "definition": "Angle with vertex at the origin and initial side on the positive x-axis."
    }
  ]
}