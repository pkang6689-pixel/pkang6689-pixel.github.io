    {
      "question_number": 6,
      "question_text": "Law of sines: a/sin A = b/sin B. If a = 10, A = 30°, B = 60°, find b.",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "5",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "10√3 ≈ 17.32",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "20",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "10",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "10/sin 30° = b/sin 60° → 10/0.5 = b/(√3/2) → 20 = b/(√3/2) → b = 10√3."
    },
    {
      "question_number": 7,
      "question_text": "Law of cosines: c² = a² + b² − 2ab cos C. If a = 5, b = 7, C = 60°, find c.",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "12",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "√74",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "√39 ≈ 6.24",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "8",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "c² = 25 + 49 − 2(5)(7)(0.5) = 74 − 35 = 39. c = √39 ≈ 6.24."
    },
    {
      "question_number": 8,
      "question_text": "If C = 90° in the law of cosines, it reduces to:",
