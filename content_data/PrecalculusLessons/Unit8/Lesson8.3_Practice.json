  "title": "Sigma Notation & Summation Rules",
  "course": "Precalculus",
  "flashcards": [
    {
      "term": "Sigma Notation",
      "definition": "Σ_{k=m}^{n} a_k represents the sum from k=m to k=n."
    },
    {
      "term": "Sum of First n Integers",
      "definition": "Σ k = n(n+1)/2."
    },
    {
      "term": "Sum of First n Squares",
      "definition": "Σ k² = n(n+1)(2n+1)/6."
    },
    {
      "term": "Linearity Property",
      "definition": "Σ(ca_k + b_k) = cΣa_k + Σb_k."
    },
    {
      "term": "Telescoping Sum",
      "definition": "A sum where consecutive terms cancel, leaving only the first and last parts."
    }
  ]
}