{
  "unit": 8,
  "lesson_number": "8.2",
  "title": "Geometric Sequences (nth term, infinite series)",
  "course": "Precalculus",
  "flashcards": [
    {
      "term": "Common Ratio r",
      "definition": "r = a_{n+1}/a_n; constant for geometric sequences."
    },
    {
      "term": "nth Term Formula",
      "definition": "a_n = a_1 · r^(n−1)."
    },
    {
      "term": "Finite Sum Formula",
      "definition": "S_n = a_1(1 − rⁿ)/(1 − r) for r ≠ 1."
    },
    {
      "term": "Infinite Sum (Convergent)",
      "definition": "If |r| < 1, S = a_1/(1 − r)."
    },
    {
      "term": "Divergent Series",
      "definition": "If |r| ≥ 1, the infinite geometric series diverges."
    }
  ]
}