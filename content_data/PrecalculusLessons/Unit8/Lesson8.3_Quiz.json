    {
      "question_number": 13,
      "question_text": "What does the 'summation property of addition' state?",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "Σ(aₖ + bₖ) = Σ aₖ + Σ bₖ",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "Σ(aₖ + bₖ) = Σ aₖ · Σ bₖ",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Σ aₖ = Σ bₖ if aₖ = bₖ",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Σ(aₖ · bₖ) = Σ aₖ · Σ bₖ",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "The sum of sums property says that the sigma of a sum equals the sum of the sigmas: Σ(aₖ + bₖ) = Σ aₖ + Σ bₖ."
    },
