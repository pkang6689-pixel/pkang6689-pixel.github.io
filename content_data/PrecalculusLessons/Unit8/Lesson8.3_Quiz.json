    {
      "question_number": 11,
      "question_text": "What is 'sigma notation'?",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "A compact way to write a sum using the Greek letter Σ, an index variable, and upper/lower bounds",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "A notation for writing products using the Greek letter Π",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "A method for multiplying sequences of numbers",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "A way to express fractions in lowest terms",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "Sigma notation uses Σ with an index, lower bound, and upper bound to compactly express the sum of a sequence of terms."
    },
