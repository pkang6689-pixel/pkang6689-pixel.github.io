{
  "unit": 5,
  "lesson_number": "5.3",
  "title": "Properties of Logarithms",
  "course": "Precalculus",
  "flashcards": [
    {
      "term": "Logarithm",
      "definition": "The inverse of exponentiation: log_b(y) = x means bˣ = y."
    },
    {
      "term": "Product Rule",
      "definition": "log_b(MN) = log_b(M) + log_b(N)."
    },
    {
      "term": "Quotient Rule",
      "definition": "log_b(M/N) = log_b(M) − log_b(N)."
    },
    {
      "term": "Power Rule",
      "definition": "log_b(Mⁿ) = n · log_b(M)."
    },
    {
      "term": "Natural Logarithm (ln)",
      "definition": "log base e; ln(x) = logₑ(x). Inverse of eˣ."
    }
  ]
}