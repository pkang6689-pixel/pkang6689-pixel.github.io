  "unit": 7,
  "lesson_number": "7.4",
  "title": "Product-to-Sum and Sum-to-Product Identities",
  "course": "Precalculus",
  "flashcards": [
    {
      "term": "Product-to-Sum: sin A cos B",
      "definition": "(1/2)[sin(A+B) + sin(A−B)]."
    },
    {
      "term": "Product-to-Sum: cos A cos B",
      "definition": "(1/2)[cos(A−B) + cos(A+B)]."
    },
    {
      "term": "Product-to-Sum: sin A sin B",
      "definition": "(1/2)[cos(A−B) − cos(A+B)]."
    },
    {
      "term": "Sum-to-Product: sin C + sin D",
      "definition": "2 sin((C+D)/2) cos((C−D)/2)."
    },
    {
      "term": "Sum-to-Product: cos C − cos D",
      "definition": "−2 sin((C+D)/2) sin((C−D)/2)."
    }
  ]
}