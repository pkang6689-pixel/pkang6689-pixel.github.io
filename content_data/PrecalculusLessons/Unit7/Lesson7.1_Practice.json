  "title": "Pythagorean Identities",
  "course": "Precalculus",
  "flashcards": [
    {
      "term": "Fundamental Pythagorean Identity",
      "definition": "sin²θ + cos²θ = 1."
    },
    {
      "term": "Tangent-Secant Identity",
      "definition": "1 + tan²θ = sec²θ."
    },
    {
      "term": "Cotangent-Cosecant Identity",
      "definition": "1 + cot²θ = csc²θ."
    },
    {
      "term": "Verifying Identities",
      "definition": "Transform one side of the equation to match the other using known identities."
    },
    {
      "term": "Strategy: Convert to sin/cos",
      "definition": "Replace all trig functions with sin θ and cos θ to simplify."
    }
  ]
}