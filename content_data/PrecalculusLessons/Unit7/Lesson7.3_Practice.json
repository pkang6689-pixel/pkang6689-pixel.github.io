{
  "unit": 7,
  "lesson_number": "7.3",
  "title": "Double-Angle & Half-Angle Formulas",
  "course": "Precalculus",
  "flashcards": [
    {
      "term": "Double-Angle for Sine",
      "definition": "sin 2θ = 2 sin θ cos θ."
    },
    {
      "term": "Double-Angle for Cosine",
      "definition": "cos 2θ = cos²θ − sin²θ = 2cos²θ − 1 = 1 − 2sin²θ."
    },
    {
      "term": "Double-Angle for Tangent",
      "definition": "tan 2θ = 2 tan θ/(1 − tan²θ)."
    },
    {
      "term": "Half-Angle for Sine",
      "definition": "sin(θ/2) = ±√((1 − cos θ)/2); sign by quadrant."
    },
    {
      "term": "Half-Angle for Cosine",
      "definition": "cos(θ/2) = ±√((1 + cos θ)/2); sign by quadrant."
    }
  ]
}