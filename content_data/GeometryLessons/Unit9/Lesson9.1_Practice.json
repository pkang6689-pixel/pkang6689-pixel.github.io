  "title": "Reflections",
  "course": "Geometry",
  "flashcards": [
    {
      "term": "Reflection",
      "definition": "A transformation that flips a figure over a line of reflection."
    },
    {
      "term": "Line of Reflection",
      "definition": "The 'mirror line'; every point and its image are equidistant from this line."
    },
    {
      "term": "Reflection over x-axis",
      "definition": "(x, y) → (x, −y)."
    },
    {
      "term": "Reflection over y-axis",
      "definition": "(x, y) → (−x, y)."
    },
    {
      "term": "Reflection over y = x",
      "definition": "(x, y) → (y, x)."
    }
  ]
}