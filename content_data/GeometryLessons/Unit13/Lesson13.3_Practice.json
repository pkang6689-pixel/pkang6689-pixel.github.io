  "title": "Geometric Probability",
  "course": "Geometry",
  "flashcards": [
    {
      "term": "Geometric Probability",
      "definition": "Probability based on areas, lengths, or volumes rather than counting outcomes."
    },
    {
      "term": "Length Probability",
      "definition": "P = favorable length / total length."
    },
    {
      "term": "Area Probability",
      "definition": "P = favorable area / total area."
    },
    {
      "term": "Random Point",
      "definition": "A point chosen randomly, with equal likelihood anywhere in the region."
    },
    {
      "term": "Application",
      "definition": "Dart boards, landing zones, spinner problems."
    }
  ]
}