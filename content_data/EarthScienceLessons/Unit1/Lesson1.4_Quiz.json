      "question_number": 1,
      "question_text": "Which process transforms sedimentary rock into metamorphic rock?",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "Melting",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Weathering",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Cooling",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "Increased heat and pressure",
          "is_correct": true,
          "data_i18n": null
        }
      ],
      "explanation": "When sedimentary rocks are buried deeply, increased heat and pressure cause their minerals to recrystallize without melting, creating metamorphic rock."
    },
    {
