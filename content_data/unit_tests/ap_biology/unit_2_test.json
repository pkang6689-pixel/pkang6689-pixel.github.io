  "questions": [
    {
      "q": "A student observes a cell under the light microscope and notes that it contains a nucleus and several membrane-bound organelles. This cell is most likely __________.",
      "type": "mc",
      "options": [
        "prokaryotic",
        "eukaryotic from a plant",
        "eukaryotic from an animal",
        "eukaryotic"
      ],
      "answer": "eukaryotic",
      "difficulty": "easy",
      "id": "u2_q1",
      "source": "College Board Released Exam"
    },
    {
      "q": "Prokaryotic cells lack a membrane-bound nucleus and also lack __________.",
      "type": "mc",
      "options": [
        "cell membranes",
        "ribosomes",
        "other membrane-bound organelles",
        "cell walls"
      ],
      "answer": "other membrane-bound organelles",
      "difficulty": "medium",
      "id": "u2_q2",
      "source": "College Board Released Exam"
    },
    {
      "q": "The endoplasmic reticulum with ribosomes attached is called the __________.",
      "type": "mc",
      "options": [
        "Golgi apparatus",
        "rough endoplasmic reticulum",
        "smooth endoplasmic reticulum",
        "golgi bodies"
      ],
      "answer": "rough endoplasmic reticulum",
      "difficulty": "hard",
      "id": "u2_q3",
      "source": "College Board Released Exam"
    },
    {
      "q": "Which of the following describes the fluid mosaic model of the cell membrane?",
      "type": "mc",
      "options": [
        "The cell membrane is solid and rigid",
        "Phospholipids and proteins move within the cell membrane",
        "The cell membrane remains stationary",
        "Only proteins move within the membrane"
      ],
      "answer": "Phospholipids and proteins move within the cell membrane",
      "difficulty": "easy",
      "id": "u2_q4",
      "source": "College Board Released Exam"
    },
    {
      "q": "The sodium-potassium pump moves sodium and potassium ions against their concentration gradients. This is an example of __________.",
      "type": "mc",
      "options": [
        "osmosis",
        "diffusion",
        "active transport",
        "facilitated diffusion"
      ],
      "answer": "active transport",
      "difficulty": "medium",
      "id": "u2_q5",
      "source": "College Board Released Exam"
    },
    {
      "q": "A plant cell is placed in a hypertonic solution and water begins to leave the cell. The cell membrane pulls away from the cell wall in this process called __________.",
