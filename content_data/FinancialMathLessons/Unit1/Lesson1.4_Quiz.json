    {
      "question_number": 6,
      "question_text": "Opportunity cost of buying a $1,000 designer bag is:",
      "attempted": 2,
      "data_i18n": null,
      "options": [
        {
          "text": "Zero — you still have the bag, so you haven't lost anything",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "$1,000",
          "is_correct": false,
          "data_i18n": null
        },
        {
          "text": "The value of what else that $1,000 could have been used for (e.g., invested, saving, emergency fund)",
          "is_correct": true,
          "data_i18n": null
        },
        {
          "text": "The sales tax paid on the purchase",
          "is_correct": false,
          "data_i18n": null
        }
      ],
      "explanation": "Opportunity cost isn't the price you paid — it's the value of the best alternative you gave up. The $1,000 could have earned compound interest in investments, padded your emergency fund, or paid down debt. Simply stating '$1,000' confuses the price with the opportunity cost, which includes the time value of money."
    },
